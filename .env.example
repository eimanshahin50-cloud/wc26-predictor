# ----- Database (Supabase / Neon / Vercel Postgres) -----
# Pooled connection string (used at runtime):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (used by `prisma migrate`/`db push`). On Supabase use port 5432:
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ----- Auth -----
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"   # set to your production URL on Vercel

# ----- Seeded account passwords (used by prisma/seed.ts) -----
AMATEUR_PASSWORD="changeme-amateur"
NXTMV_PASSWORD="changeme-nxtmv"

# ----- Football API (API-Football / api-sports.io) -----
# >>> THE ONE PLACE YOU PUT YOUR API KEY <<<
FOOTBALL_API_KEY="your-api-football-key"
FOOTBALL_LEAGUE_ID="1"     # World Cup league id — VERIFY against /leagues
FOOTBALL_SEASON="2026"

# ----- Cron protection -----
# Generate with: openssl rand -hex 16  (Vercel sends this as a Bearer token)
CRON_SECRET="replace-me"
